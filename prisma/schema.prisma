// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  imageUrl       String
  price          Float
  priceCurrency  String   @default("EUR")
  description    String
  exchangeRate   Float?
  exchangeRateAt DateTime?
  priceRon       Float?
  sourceUrl      String?
  scrapedAt      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ScrapeRun {
  id              Int       @id @default(autoincrement())
  trigger         String
  status          String
  productsFound   Int       @default(0)
  productsChanged Int       @default(0)
  message         String?
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
}

model InvoiceImport {
  id            Int           @id @default(autoincrement())
  fileName      String
  invoiceNumber String?
  issuedAt      DateTime?
  rowsCount     Int           @default(0)
  createdAt     DateTime      @default(now())
  items         InvoiceItem[]
}

model InvoiceItem {
  id           Int           @id @default(autoincrement())
  importId     Int
  productCode  String
  productName  String
  unitPrice    Float
  currency     String
  quantity     Float
  lineNumber   Int?
  createdAt    DateTime      @default(now())
  import       InvoiceImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
}
